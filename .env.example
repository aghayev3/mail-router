# ============================================================
# .env.example — copy this to .env and fill in real values,
# OR just run: python setup.py
# NEVER commit your actual .env file to version control.
# ============================================================

# ── Email provider ──────────────────────────────────────────
# Set to "m365" or "gmail"
EMAIL_PROVIDER=m365

# ── Gemini API ──────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Microsoft 365 (only needed if EMAIL_PROVIDER=m365) ──────
M365_TENANT_ID=your-tenant-id-here
M365_CLIENT_ID=your-client-id-here
M365_CLIENT_SECRET=your-client-secret-here
M365_MAILBOX=it-support@yourcompany.com

# ── Gmail (only needed if EMAIL_PROVIDER=gmail) ─────────────
# Run: python providers/gmail_auth.py --credentials client_secret.json
GMAIL_CLIENT_ID=your-gmail-client-id-here
GMAIL_CLIENT_SECRET=your-gmail-client-secret-here
GMAIL_REFRESH_TOKEN=your-refresh-token-here
GMAIL_ADDRESS=your-gmail@gmail.com

# ── Polling ─────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60

# ── Department routing targets ──────────────────────────────
EMAIL_HELP_DESK=helpdesk@yourcompany.com
EMAIL_NETWORKING=networking@yourcompany.com
EMAIL_CYBERSECURITY=cybersecurity@yourcompany.com
EMAIL_SYSADMIN=sysadmin@yourcompany.com
EMAIL_FALLBACK=it-triage@yourcompany.com

# ── Classification ──────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.70
FALLBACK_QUEUE_PATH=fallback_queue.jsonl

# ── Health server ────────────────────────────────────────────
HEALTH_PORT=8080

# ── Alerting (leave ALERT_SMTP_HOST blank to disable alerts) ─
ALERT_SMTP_HOST=smtp.yourcompany.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=alerts@yourcompany.com
ALERT_SMTP_PASSWORD=your-smtp-password
ALERT_FROM_ADDRESS=it-router@yourcompany.com
ALERT_TO_ADDRESS=it-admin@yourcompany.com
ALERT_CONSECUTIVE_FAILURES=5

# ── Fallback queue alerting ──────────────────────────────────
FALLBACK_ALERT_THRESHOLD=10

# ── Deduplication DB ─────────────────────────────────────────
DEDUP_DB_PATH=data/processed_emails.db
DEDUP_PRUNE_DAYS=90
